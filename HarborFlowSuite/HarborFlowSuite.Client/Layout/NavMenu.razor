@using Microsoft.AspNetCore.Components.Authorization
@using HarborFlowSuite.Abstractions.Services
@using HarborFlowSuite.Client.Services
@inject IClientAuthService AuthService
@inject NavigationManager NavigationManager
@inject MediaQuery Media

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">HarborFlowSuite.Client</a>
    </div>
</div>

<div class="nav-scrollable">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link home-nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> <span class="nav-link-text">Home</span>
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="dashboard">
                        <span class="bi bi-speedometer" aria-hidden="true"></span> <span class="nav-link-text">Dashboard</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="nautical-chart">
                        <span class="bi bi-map-fill" aria-hidden="true"></span> <span class="nav-link-text">Nautical Chart</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="vessel-management">
                        <span class="fas fa-ship" aria-hidden="true"></span> <span class="nav-link-text">Vessel Management</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="service-request-management">
                        <span class="bi bi-tools" aria-hidden="true"></span> <span class="nav-link-text">Service Requests</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="company-management">
                        <span class="bi bi-building-fill" aria-hidden="true"></span> <span class="nav-link-text">Company Management</span>
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>

<div class="nav-item px-3 logout-button">
    <AuthorizeView>
        <Authorized>
            @if (MediaQuery.IsDesktop)
            {
                <button class="nav-link btn btn-link" @onclick="HandleLogout">
                    <span class="bi bi-box-arrow-right" aria-hidden="true"></span> <span class="nav-link-text">Log out</span>
                </button>
            }
        </Authorized>
    </AuthorizeView>
</div>

@code {
    private async Task HandleLogout()
    {
        await AuthService.SignOut();
        NavigationManager.NavigateTo("/");
    }
}
