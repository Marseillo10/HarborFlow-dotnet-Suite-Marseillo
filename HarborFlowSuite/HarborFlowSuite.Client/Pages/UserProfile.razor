@page "/authentication/profile"
@using HarborFlowSuite.Core.DTOs
@using HarborFlowSuite.Abstractions.Services
@using HarborFlowSuite.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IClientAuthService AuthService
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager

<h3>User Profile</h3>

@if (_userProfile == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="card">
        <div class="card-body">
            <EditForm Model="@_userProfile" OnValidSubmit="HandleProfileUpdate">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">
                    <label for="fullName">Full Name</label>
                    <InputText id="fullName" class="form-control" @bind-Value="_userProfile.FullName" />
                </div>

                <div class="form-group">
                    <label for="email">Email</label>
                    <InputText id="email" class="form-control" @bind-Value="_userProfile.Email" readonly />
                </div>

                <div class="form-group">
                    <label for="role">Role</label>
                    <InputText id="role" class="form-control" @bind-Value="_userProfile.Role" readonly />
                </div>

                <div class="form-group">
                    <label for="company">Company</label>
                    <InputText id="company" class="form-control" @bind-Value="_userProfile.CompanyName" readonly />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>

            <hr />

            <button class="btn btn-secondary" @onclick="HandleChangePassword">Change Password</button>
        </div>
    </div>
}

@code {
    private UserProfileDto? _userProfile;
    private HttpClient? _httpClient;

    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _httpClient = HttpClientFactory.CreateClient("HarborFlowSuite.ServerAPI");

        if (authenticationState != null)
        {
            var authState = await authenticationState;
            var user = authState.User;

            if (user.Identity != null && user.Identity.IsAuthenticated)
            {
                _userProfile = await _httpClient.GetFromJsonAsync<UserProfileDto>("api/userprofile");
            }
            else
            {
                // Optionally, redirect to login or show a message
                NavigationManager.NavigateTo("/authentication/login");
            }
        }
    }

    private async Task HandleProfileUpdate()
    {
        if (_httpClient != null)
        {
            await _httpClient.PutAsJsonAsync("api/userprofile", _userProfile);
        }
    }

    private async Task HandleChangePassword()
    {
        if (_httpClient != null)
        {
            await _httpClient.PostAsync("api/userprofile/changepassword", null);
        }
    }
}