@using Microsoft.AspNetCore.Components
@using MudBlazor

<MudTextField @bind-value="SearchTerm" Label="Search Vessels" Variant="Variant.Outlined" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search" OnAdornmentClick="OnSearch" OnKeyUp="HandleKeyUp" />

@code {
    [Parameter]
    public EventCallback<string> OnSearchTermChanged { get; set; }

    private string SearchTerm { get; set; } = string.Empty;

    private async Task OnSearch()
    {
        await OnSearchTermChanged.InvokeAsync(SearchTerm);
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await OnSearch();
        }
    }
}
